# ============================================================
# Production Environment Variables for Coolify
# Copy these into Coolify > Application > Environment Variables
# ============================================================

# --- Database ---
POSTGRES_USER=emailhub
POSTGRES_PASSWORD=<generate-strong-password>
POSTGRES_DB=email_hub

# --- Redis ---
REDIS_PASSWORD=<generate-strong-password>

# --- App ---
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Auth (Backend JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH__JWT_SECRET_KEY=<generate-secret>
AUTH__DEMO_USER_PASSWORD=<your-password>

# --- Auth (Frontend NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=<generate-secret>
# IMPORTANT: Set to the public URL of your deployment (no trailing slash)
AUTH_URL=http://204.168.129.30
AUTH_TRUST_HOST=true

# --- AI ---
AI__PROVIDER=anthropic
AI__API_KEY=<your-anthropic-api-key>
AI__MODEL=claude-sonnet-4-20250514

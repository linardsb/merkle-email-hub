<!-- section:{{ section.node_id }}:{{ section.section_type }} -->
<mj-section background-color="{{ section.bg_color or palette.primary }}" padding="{{ section_padding }}"{% for img in section.images %}{% if img.is_background %} background-url="https://placehold.co/{{ (img.width or container_width)|int }}x{{ (img.height or 400)|int }}" background-size="cover"{% endif %}{% endfor %}>
  <mj-column>
{% for text in section.texts %}
{% if text.is_heading %}
    <mj-text font-size="{{ typo.base_size }}" font-weight="700" line-height="{{ typo.heading_line_height or '1.3' }}" color="#ffffff" font-family="{{ typo.heading_font }}" align="center" padding="10px 25px">
      <h1 style="margin:0;">{{ text.content }}</h1>
    </mj-text>
{% else %}
    <mj-text font-size="{{ typo.base_size }}" line-height="{{ typo.body_line_height or '1.5' }}" color="#ffffff" font-family="{{ typo.body_font }}" align="center" padding="10px 25px">
      {{ text.content }}
    </mj-text>
{% endif %}
{% endfor %}
{% for img in section.images %}
{% if not img.is_background %}
    <mj-image src="https://placehold.co/{{ (img.width or 560)|int }}x{{ (img.height or 300)|int }}" alt="{{ img.node_name }}" width="{{ (img.width or 560)|int }}px" padding="10px 25px" />
{% endif %}
{% endfor %}
{% for btn in section.buttons %}
    <mj-button background-color="{{ palette.accent }}" color="#ffffff" font-family="{{ typo.body_font }}" font-size="{{ typo.base_size }}" href="#" border-radius="4px" inner-padding="12px 25px" height="44px" align="center">
      {{ btn.text }}
    </mj-button>
{% endfor %}
  </mj-column>
</mj-section>

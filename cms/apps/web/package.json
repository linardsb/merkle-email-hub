{
  "name": "@email-hub/web",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "next dev --turbopack --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"e2e/**/*.{ts,tsx,js}\" \"scripts/**/*.{mjs,js,ts}\" \"*.{ts,tsx,mjs,js,jsx,json,css}\" --ignore-unknown --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"e2e/**/*.{ts,tsx,js}\" \"scripts/**/*.{mjs,js,ts}\" \"*.{ts,tsx,mjs,js,jsx,json,css}\" --ignore-unknown --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:firefox": "BROWSER=firefox playwright test",
    "e2e:webkit": "BROWSER=webkit playwright test",
    "e2e:all": "BROWSER=all playwright test",
    "e2e:smoke": "playwright test --grep @smoke"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@email-hub/sdk": "workspace:*",
    "@email-hub/ui": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.2",
    "lucide-react": "^0.474.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.0",
    "swr": "^2.3.0",
    "tailwind-merge": "^3.0.0",
    "y-monaco": "^0.1.6",
    "y-protocols": "^1.0.7",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.29",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@email-hub/typescript-config": "workspace:*",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}

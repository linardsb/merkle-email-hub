{
  "name": "@email-hub/sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-sdk": "openapi-ts",
    "generate-sdk:fetch": "curl -sf http://localhost:8891/openapi.json | python3 -m json.tool > openapi.json && openapi-ts",
    "build": "tsc"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/client/types.gen.ts"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@email-hub/typescript-config": "workspace:*",
    "@hey-api/openapi-ts": "^0.66.0",
    "typescript": "^6.0.3"
  }
}

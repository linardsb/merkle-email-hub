#!/usr/bin/env bash
# Pre-commit hook: security lint + secrets detection
set -euo pipefail

echo "Running pre-commit checks..."

# Check for common secrets patterns in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Check for potential secrets
SECRET_PATTERNS=(
    "PRIVATE.KEY"
    "BEGIN RSA"
    "BEGIN DSA"
    "BEGIN EC"
    "BEGIN OPENSSH"
    "password.*=.*['\"](?!.*CHANGE|.*example|.*placeholder)"
    "api.key.*=.*['\"][a-zA-Z0-9]{20,}"
    "secret.*=.*['\"][a-zA-Z0-9]{20,}"
)

FOUND_SECRETS=0
for pattern in "${SECRET_PATTERNS[@]}"; do
    if echo "$STAGED_FILES" | xargs grep -lP "$pattern" 2>/dev/null | grep -v ".example" | grep -v "test_" | grep -v "__pycache__"; then
        echo "WARNING: Possible secret detected with pattern: $pattern"
        FOUND_SECRETS=1
    fi
done

if [ "$FOUND_SECRETS" -eq 1 ]; then
    echo ""
    echo "Potential secrets detected in staged files."
    echo "If these are intentional (test fixtures, examples), use: git commit --no-verify"
    exit 1
fi

# Run security lint on Python files
PY_FILES=$(echo "$STAGED_FILES" | grep '\.py$' || true)
if [ -n "$PY_FILES" ]; then
    echo "Running security lint on Python files..."
    uv run ruff check --select=S --no-fix $PY_FILES
fi

echo "Pre-commit checks passed."

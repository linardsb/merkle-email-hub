# Build artifacts
cms/apps/web/.next/
cms/apps/web/next-env.d.ts
# cms/packages/sdk/src/client/  # Tracked — needed for Vercel deployment

# MCP config (contains API tokens)
.mcp.json

# Proprietary content (never committed)
index.html
pitch.html
sections-private.js
pricing.md

# Eval traces (may contain LLM outputs)
traces/*.jsonl
traces/*.json
!traces/baseline.json
traces/suggestions/*.md

# Uploaded template eval cases (generated at runtime)
app/ai/agents/evals/data/uploaded_golden/*.json

# Session handoff (transient, not committed)
HANDOFF.md

# Playwright E2E auth state (generated at runtime)
.e2e-auth-state

# Correction pattern tracking (runtime data, Phase 35.7)
data/correction_patterns.jsonl
data/correction_rules.json

# Visual regression diff images (generated on failure)
app/rendering/tests/visual_regression/baselines/_diffs/

# Runtime Figma image cache (ephemeral, rebuilt on demand)
data/design-assets/

# Mutation testing cache (Phase 2 §2.3)
.mutmut-cache
mutants/

# Coverage data (generated by pytest --cov)
.coverage
.coverage.*
htmlcov/

# Snapshot test diff output (generated on mismatch)
data/debug/*/actual.html

# Visual regression artifacts (generated by make snapshot-visual)
data/debug/*/rendered.png
data/debug/*/rendered_resized.png
data/debug/*/reference_rendered.png
data/debug/*/diff.png
data/debug/*/reference_diff.png
data/debug/*/visual_report.json
data/debug/*/_visual_test.html

# Stray local debug / build artifacts (F063)
# NOTE: data/debug/ holds both committed fixtures (expected.html, manifest.yaml,
# vlm_classifications.json) and per-run regenerable debug output. We ignore the
# regenerable bits explicitly rather than nuking the whole tree.
=2.0
*.zip
data/debug/*/actual-with-flags.html
data/debug/*/raw_figma.json
data/debug/*/structure.json
data/debug/*/tokens.json
data/debug/*/report.json
data/debug/*/assets/
e2e-screenshots/

# Claude Code session state + MCP caches (machine-local, never commit)
.claude-merkle/
.claude/projects/
.claude/worktrees/

# Figma export cache (~26 MB of design preview PNGs + JSON manifests).
# Regenerable from Figma on demand; not source-of-truth content.
.agents/figma-cache/

# Playwright test runner state (per-machine, regenerated on each run)
cms/apps/web/test-results/

# Hypothesis property-based testing cache (auto-generated, OS-specific)
.hypothesis/

# Oversized debug/review artefacts (regenerable; do not commit)
docs/*.png
docs/eval-review-data.json

# Eval verdict baselines from prior phase comparisons (historical, do not
# expect to evolve; commit baseline.json explicitly when needed)
traces/pre_*/

# Rendered template preview screenshots (regenerable from Figma; large
# binaries do not belong in git history). Specific paths only — small
# template assets (icons, hero, social) under reframe-assets/ stay tracked.
email-templates/reframe.png
email-templates/reframe-assets/email-full.png
email-templates/game_recap/game_recap.png
email-templates/training_HTML/**/*.png

# Icons/ source library (~305 MB / 10,416 files). Only the 309 SVGs
# referenced by cms/apps/web/scripts/generate-icons.mjs are committed
# (force-added). Everything else stays out — pull from the design library
# when needed and force-add specific files: git add -f email-templates/Icons/...
email-templates/Icons/

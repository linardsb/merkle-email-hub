# ── Docker Stack Environment Variables ──

# Core
ENVIRONMENT=development
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_hub

# Redis
REDIS_PASSWORD=devpassword

# Auth (backend JWT)
AUTH__JWT_SECRET_KEY=dev-secret-key-minimum-32-chars-long-for-jwt

# Auth (frontend NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET=

# AI (optional — agents won't work without this)
# AI__PROVIDER=anthropic
# AI__API_KEY=sk-...
# AI__MODEL=claude-sonnet-4-20250514

# Embedding (optional — knowledge search won't work without this)
# EMBEDDING__PROVIDER=openai
# EMBEDDING__API_KEY=sk-...

# Feature flags — enable for full pipeline (all default off)
# KNOWLEDGE__CRAG_ENABLED=true
# KNOWLEDGE__ROUTER_ENABLED=true
# KNOWLEDGE__HTML_CHUNKING_ENABLED=true
# KNOWLEDGE__MULTI_REP_ENABLED=true
# AI__ADAPTIVE_ROUTING_ENABLED=true
# BLUEPRINT__CHECKPOINTS_ENABLED=true
# COGNEE__PREFETCH_ENABLED=true
# AI__VISUAL_QA_AUTOFIX_ENABLED=false
# AI__VISUAL_QA_AUTOFIX_MAX_ROUNDS=1
# AI__MULTIMODAL_CONTEXT_ENABLED=false
# QA_CHAOS__ENABLED=false
# QA_PROPERTY_TESTING__ENABLED=false
# QA_OUTLOOK_ANALYZER__ENABLED=false
# QA_OUTLOOK_ANALYZER__DEFAULT_TARGET=dual_support
# EMAIL_ENGINE__CSS_COMPILER_ENABLED=false
# EMAIL_ENGINE__CSS_COMPILER_TARGET_CLIENTS=["gmail_web","outlook_2019","apple_mail","yahoo_mail"]
# QA_DELIVERABILITY__ENABLED=false
# QA_DELIVERABILITY__THRESHOLD=70
# CHANGE_DETECTION__ENABLED=false
# CHANGE_DETECTION__INTERVAL_HOURS=168
# CHANGE_DETECTION__DIFF_THRESHOLD=0.02
# CHANGE_DETECTION__CLIENTS=["gmail_web","outlook_2019","apple_mail","outlook_dark","mobile_ios"]
# QA_GMAIL_PREDICTOR__ENABLED=false
# QA_GMAIL_PREDICTOR__MODEL=gpt-4o-mini
# QA_GMAIL_PREDICTOR__API_BASE_URL=https://api.openai.com/v1
# QA_GMAIL_PREDICTOR__API_KEY=

# Token budget management (Phase 22.3)
# AI__TOKEN_BUDGET_ENABLED=false
# AI__TOKEN_BUDGET_RESERVE=4096
# AI__TOKEN_BUDGET_MAX=0

# Fallback chains — ordered model fallbacks per tier (Phase 22.4)
# Format: {"tier": ["provider:model", ...]}
# Example: {"complex": ["anthropic:claude-opus-4-6", "openai:gpt-4o"], "standard": ["anthropic:claude-sonnet-4-6", "openai:gpt-4o-mini"]}
# AI__FALLBACK_CHAINS={}

# Model capability registry (Phase 22.1) — JSON array of model specs
# AI__MODEL_SPECS='[{"model_id":"claude-sonnet-4-20250514","provider":"anthropic","tier":"standard","capabilities":["vision","tool_use","structured_output"],"context_window":200000,"max_output_tokens":8192,"cost_per_input_token":0.000003,"cost_per_output_token":0.000015}]'

# ── Voice Pipeline (Phase 23.5) ──
VOICE__ENABLED=false
VOICE__TRANSCRIBER=openai
VOICE__WHISPER_MODEL=whisper-1
VOICE__MAX_DURATION_S=300
VOICE__MAX_FILE_SIZE_MB=25
VOICE__CONFIDENCE_THRESHOLD=0.7

# ── MCP Tool Server (Phase 23.4) ──
MCP__ENABLED=false
MCP__MAX_RESPONSE_TOKENS=4096
MCP__TOOL_TIMEOUT_S=30
MCP__AUDIT_LOG_ENABLED=true
# MCP__TOOL_ALLOWLIST=  # comma-separated, empty = all tools

# ── BIMI Readiness ──
QA_BIMI__ENABLED=true
QA_BIMI__SVG_FETCH_TIMEOUT_SECONDS=10

# ── Email Engine Schema.org ──
EMAIL_ENGINE__SCHEMA_INJECTION_ENABLED=false
# EMAIL_ENGINE__SCHEMA_INJECTION_TYPES=  # comma-separated

# ── Maizzle Builder Sidecar ──
MAIZZLE_BUILDER_URL=http://localhost:3001

# ── Collaboration WebSocket (Phase 24.2 CRDT) ──
COLLAB_WS__CRDT_ENABLED=false
COLLAB_WS__CRDT_COMPACTION_THRESHOLD=100
COLLAB_WS__CRDT_MAX_DOCUMENT_SIZE_MB=5

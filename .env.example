# ── Docker Stack Environment Variables ──
# This file is generated by scripts/generate-env-example.py — edit there.

# Core
ENVIRONMENT=development
LOG_LEVEL=INFO

# PostgreSQL (docker-compose; backend reads DATABASE__URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_hub

# Redis (docker-compose only; backend reads REDIS__URL)
REDIS_PASSWORD=devpassword

# Auth (frontend NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Backend Settings (auto-generated from app.core.config.Settings) ──

APP_NAME=email-hub
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
LOGGING_PII_REDACTION=true
API_PREFIX=/api
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8891", "http://localhost:8899"]

# ── DatabaseConfig ──
DATABASE__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/email_hub
DATABASE__POOL_SIZE=20
DATABASE__POOL_MAX_OVERFLOW=20
DATABASE__POOL_RECYCLE=1800

# ── RedisConfig ──
REDIS__URL=redis://localhost:6379/0

# ── AuthConfig ──
# HS256 signing key; must be >=32 chars (256 bits). Production refuses the default placeholder.
AUTH__JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-this-is-not-a-real-secret
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH__REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH__DEMO_USER_EMAIL=demo@example.com
AUTH__DEMO_USER_PASSWORD=admin

